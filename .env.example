# Copy this file to `.env` and fill in your real keys.
# `.env` is gitignored — never commit real keys.

# ChatPDF API key — used to generate flashcards from PDFs.
# Get one at https://www.chatpdf.com/docs/api/backend
chatPdfApi=your_chatpdf_api_key

# RapidAPI key (if you use a RapidAPI-hosted endpoint).
RAPID_API_KEY=your_rapidapi_key
